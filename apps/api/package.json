{
  "name": "@bondexos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build -w @bondexos/shared && tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run build -w @bondexos/shared && tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @bondexos/shared && vitest run",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "@bondexos/integrations": "0.1.0",
    "@bondexos/shared": "0.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "node-mocks-http": "^1.17.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
